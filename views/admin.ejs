<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Dashboard - OWCS Tipping</title>
  <link rel="stylesheet" href="/stylesheets/global.css">
  <link rel="stylesheet" href="/stylesheets/layout.css">
  <link rel="stylesheet" href="/stylesheets/components.css">
  <link rel="stylesheet" href="/stylesheets/interactive.css">
  <link rel="stylesheet" href="/stylesheets/match-cards.css">
  <link rel="stylesheet" href="/stylesheets/pages/admin.css">
  <link rel="icon" href="/favicon.ico" type="image/x-icon">

  <script>
    if (localStorage.getItem('darkMode') === 'true') {
      document.documentElement.classList.add('dark-mode');
    }
  </script>
</head>

<body>
  <%- include('partials/header') %>

  <main class="page-shell">
    <section class="page-hero">
      <div class="container">
        <h1>Admin Dashboard</h1>
        <p>Manage matches, users, teams and content — and keep an eye on anything that needs fixing.</p>
      </div>
    </section>

    <section class="page-content">
      <div class="container">

        <!-- Navigation cards -->
        <div class="admin-grid">
          <a href="/adminHealth" class="admin-card admin-card--accent">
            <span class="admin-card__icon">🩺</span>
            <span class="admin-card__title">Health &amp; Triage</span>
            <span class="admin-card__desc">Everything that needs attention, in one place.</span>
          </a>
          <a href="/adminMatches" class="admin-card">
            <span class="admin-card__icon">🎮</span>
            <span class="admin-card__title">Manage Matches</span>
            <span class="admin-card__desc">Fix results, odds and timings; resolve payouts.</span>
          </a>
          <a href="/adminUsers" class="admin-card">
            <span class="admin-card__icon">👥</span>
            <span class="admin-card__title">Manage Users</span>
            <span class="admin-card__desc">Credits, roles, badges and passwords.</span>
          </a>
          <a href="/adminAliases" class="admin-card">
            <span class="admin-card__icon">🔗</span>
            <span class="admin-card__title">Team Aliases</span>
            <span class="admin-card__desc">Map synced names and merge duplicates.</span>
          </a>
          <a href="/adminNews" class="admin-card">
            <span class="admin-card__icon">📰</span>
            <span class="admin-card__title">Manage News</span>
            <span class="admin-card__desc">Draft, publish and edit news items.</span>
          </a>
          <a href="/adminTeams" class="admin-card">
            <span class="admin-card__icon">🛡️</span>
            <span class="admin-card__title">Manage Teams</span>
            <span class="admin-card__desc">Edit team details, regions and ratings.</span>
          </a>
          <a href="/adminUpset" class="admin-card">
            <span class="admin-card__icon">⚡</span>
            <span class="admin-card__title">Manage Upsets</span>
            <span class="admin-card__desc">Override or clear flagged upsets.</span>
          </a>
        </div>

        <!-- Sync tools -->
        <div class="admin-panel">
          <div class="admin-panel__head">
            <h2>Data Sync</h2>
            <button id="runFullSyncBtn" class="btn btn-primary" type="button">Run Full Sync</button>
          </div>
          <p class="admin-panel__note">Pulls matches from Liquipedia, refreshes odds, and resolves finished matches.</p>
          <pre id="syncOutput" class="admin-sync-output"></pre>
        </div>

        <!-- Users -->
        <div class="admin-panel">
          <div class="admin-panel__head">
            <h2>Users</h2>
            <a href="/adminUsers" class="btn btn-secondary">Full User Tools &rarr;</a>
          </div>
          <div class="admin-table-wrap">
            <table id="users-table" class="admin-table">
              <thead>
                <tr>
                  <th>Username</th>
                  <th>Email</th>
                  <th>Admin?</th>
                </tr>
              </thead>
              <tbody></tbody>
            </table>
          </div>
        </div>

        <!-- Recent tips -->
        <div class="admin-panel">
          <div class="admin-panel__head">
            <h2>Recent Tips</h2>
          </div>
          <div class="admin-table-wrap">
            <table id="recent-tips-table" class="admin-table">
              <thead>
                <tr>
                  <th>User</th>
                  <th>Email</th>
                  <th>Match</th>
                  <th>Selected</th>
                  <th>Amount</th>
                  <th>Odds</th>
                  <th>Payout</th>
                  <th>Status</th>
                  <th>Placed</th>
                  <th>Ago</th>
                </tr>
              </thead>
              <tbody></tbody>
            </table>
          </div>
        </div>

      </div>
    </section>
  </main>

  <script>
    function escapeHTML(value) {
      if (value === null || value === undefined) return '';
      return String(value)
        .replaceAll('&', '&amp;')
        .replaceAll('<', '&lt;')
        .replaceAll('>', '&gt;')
        .replaceAll('"', '&quot;')
        .replaceAll("'", '&#039;');
    }
    function getBadgeHTML(badgeType) {
      if (!badgeType) return '';
      if (badgeType === 'owner') return `<span class="user-badge badge-owner">OWNER</span>`;
      if (badgeType === 'vip') return `<span class="user-badge badge-vip">VIP</span>`;
      return '';
    }
    function formatMoney(value) {
      const numberValue = Number(value);
      if (!Number.isFinite(numberValue)) return '0.00';
      return numberValue.toFixed(2);
    }
    function formatDateTime(value) {
      if (!value) return 'Unknown';
      return new Date(value).toLocaleString();
    }
    function timeAgo(date) {
      if (!date) return 'Unknown';
      const seconds = Math.floor((new Date() - new Date(date)) / 1000);
      if (seconds < 60) return `${seconds}s ago`;
      const minutes = Math.floor(seconds / 60);
      if (minutes < 60) return `${minutes}m ago`;
      const hours = Math.floor(minutes / 60);
      if (hours < 24) return `${hours}h ago`;
      const days = Math.floor(hours / 24);
      return `${days}d ago`;
    }
    function getStatusClass(status) {
      if (status === 'won') return 'admin-status--won';
      if (status === 'lost') return 'admin-status--lost';
      return 'admin-status--pending';
    }

    async function loadAllUsers() {
      try {
        const res = await fetch('/api/admin/users', { credentials: 'include' });
        if (!res.ok) throw new Error('Access denied or server error');
        const users = await res.json();
        const tbody = document.querySelector('#users-table tbody');
        tbody.innerHTML = '';
        users.forEach(user => {
          const row = document.createElement('tr');
          row.innerHTML = `
            <td><div class="username-with-badge">${escapeHTML(user.username)} ${getBadgeHTML(user.badge_type)}</div></td>
            <td>${escapeHTML(user.email)}</td>
            <td>${Number(user.is_admin) === 1 ? '✅' : '—'}</td>
          `;
          tbody.appendChild(row);
        });
      } catch (err) {
        console.error(err);
        alert('You are not authorized to view this page.');
        window.location.href = '/';
      }
    }

    const runFullSyncBtn = document.getElementById('runFullSyncBtn');
    const syncOutput = document.getElementById('syncOutput');

    runFullSyncBtn.addEventListener('click', async () => {
      runFullSyncBtn.disabled = true;
      runFullSyncBtn.textContent = 'Running Sync...';
      syncOutput.textContent = 'Running full sync. Please do not refresh this page.';
      try {
        const res = await fetch('/api/full-sync', { method: 'POST', credentials: 'include' });
        const data = await res.json();
        if (!res.ok || !data.success) throw new Error(data.error || data.message || 'Full sync failed.');
        syncOutput.textContent = 'Full sync completed successfully.';
      } catch (err) {
        console.error(err);
        syncOutput.textContent = `Full sync failed.\n\n${err.message}`;
      } finally {
        runFullSyncBtn.disabled = false;
        runFullSyncBtn.textContent = 'Run Full Sync';
      }
    });

    async function loadRecentTips() {
      try {
        const res = await fetch('/api/admin/recent-tips', { credentials: 'include' });
        if (!res.ok) throw new Error('Access denied or server error');
        const tips = await res.json();
        const tbody = document.querySelector('#recent-tips-table tbody');
        tbody.innerHTML = '';
        tips.forEach(tip => {
          const row = document.createElement('tr');
          const amount = Number(tip.amount_tipped);
          const odds = Number(tip.odds);
          const payout = amount * odds;
          row.innerHTML = `
            <td><div class="username-with-badge">${escapeHTML(tip.username)} ${getBadgeHTML(tip.badge_type)}</div></td>
            <td>${escapeHTML(tip.email)}</td>
            <td>${escapeHTML(tip.team_1_name)} vs ${escapeHTML(tip.team_2_name)}</td>
            <td>${escapeHTML(tip.selected_team_name)}</td>
            <td>${formatMoney(amount)}</td>
            <td>${formatMoney(odds)}</td>
            <td>${formatMoney(payout)}</td>
            <td><span class="admin-status ${getStatusClass(tip.status)}">${escapeHTML(tip.status)}</span></td>
            <td>${formatDateTime(tip.tip_time)}</td>
            <td>${timeAgo(tip.tip_time)}</td>
          `;
          tbody.appendChild(row);
        });
      } catch (err) {
        console.error('Error loading recent tips:', err);
      }
    }

    loadAllUsers();
    loadRecentTips();
  </script>

  <%- include('partials/footer') %>
</body>
</html>
