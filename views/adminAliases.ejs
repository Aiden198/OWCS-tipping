<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Team Aliases - Admin</title>
  <link rel="stylesheet" href="/stylesheets/global.css">
  <link rel="stylesheet" href="/stylesheets/layout.css">
  <link rel="stylesheet" href="/stylesheets/components.css">
  <link rel="stylesheet" href="/stylesheets/interactive.css">
  <link rel="stylesheet" href="/stylesheets/match-cards.css">
  <link rel="stylesheet" href="/stylesheets/pages/adminAliases.css">
  <link rel="icon" href="/favicon.ico" type="image/x-icon">
</head>
<body>
  <%- include('partials/header') %>

  <main class="page-shell">
    <section class="page-hero">
      <div class="container">
        <h1>Team Aliases</h1>
        <p>Map synced team names to the right team, and merge accidental duplicates. <a href="/admin">&larr; Back to Admin</a></p>
      </div>
    </section>

    <section class="page-content">
      <div class="container">

        <!-- Add alias -->
        <div class="al-panel">
          <h3>Add an alias</h3>
          <p class="al-help">Point a source name (e.g. how a team appears on Liquipedia) at the correct team so its matches and tips resolve.</p>
          <div class="al-add-row">
            <input type="text" id="al-add-name" placeholder="Source name, e.g. &quot;Team Falcons EU&quot;">
            <select id="al-add-team"></select>
            <button class="btn btn-primary" id="al-add-btn">Add Alias</button>
          </div>
          <div id="al-add-msg" class="al-msg"></div>
        </div>

        <div class="al-toolbar">
          <div class="al-search">
            <input type="text" id="al-search" placeholder="Filter teams / aliases...">
          </div>
          <label class="al-check">
            <input type="checkbox" id="al-unknown-only"> Only unknown-region teams
          </label>
          <span id="al-status" class="al-status"></span>
        </div>

        <div id="al-list" class="al-list"></div>
      </div>
    </section>
  </main>

  <script>
    (function () {
      const listEl = document.getElementById('al-list');
      const statusEl = document.getElementById('al-status');
      const addMsg = document.getElementById('al-add-msg');
      const addTeamSel = document.getElementById('al-add-team');

      let teams = [];

      function esc(v) {
        if (v === null || v === undefined) return '';
        return String(v)
          .replaceAll('&', '&amp;').replaceAll('<', '&lt;').replaceAll('>', '&gt;')
          .replaceAll('"', '&quot;').replaceAll("'", '&#039;');
      }

      function teamOptions(excludeId) {
        return teams
          .filter(t => t.team_id !== excludeId)
          .map(t => '<option value="' + t.team_id + '">' + esc(t.name) + '</option>')
          .join('');
      }

      function cardHTML(t) {
        const regionPill = t.unknown_region
          ? '<span class="al-pill al-pill--warn">UNKNOWN REGION</span>'
          : '<span class="al-pill">' + esc(t.region) + '</span>';

        const aliasChips = t.aliases.length
          ? t.aliases.map(a =>
              '<span class="al-chip">' + esc(a.alias_name)
              + '<button class="al-chip__x" data-alias-id="' + a.alias_id + '" title="Delete alias">&times;</button></span>'
            ).join('')
          : '<span class="al-muted">No aliases</span>';

        return '<div class="al-card" data-team-id="' + t.team_id + '">'
          + '<div class="al-card__head">'
            + '<div><span class="al-team-name">' + esc(t.name) + '</span> ' + regionPill + '</div>'
            + '<div class="al-muted">' + t.match_count + ' matches • ' + t.tip_count + ' tips • Elo ' + esc(t.rating) + '</div>'
          + '</div>'
          + '<div class="al-chips">' + aliasChips + '</div>'
          + '<div class="al-card__actions">'
            + '<div class="al-inline-add">'
              + '<input type="text" class="al-inline-name" placeholder="Add alias for this team...">'
              + '<button class="btn btn-secondary al-inline-btn" data-team-id="' + t.team_id + '">Add</button>'
            + '</div>'
            + '<div class="al-merge">'
              + '<span class="al-muted">Merge into:</span>'
              + '<select class="al-merge-target">' + teamOptions(t.team_id) + '</select>'
              + '<button class="btn btn-danger al-merge-btn" data-team-id="' + t.team_id + '">Merge</button>'
            + '</div>'
          + '</div>'
          + '<div class="al-card__msg"></div>'
        + '</div>';
      }

      function render() {
        const q = document.getElementById('al-search').value.trim().toLowerCase();
        const unknownOnly = document.getElementById('al-unknown-only').checked;

        const filtered = teams.filter(t => {
          if (unknownOnly && !t.unknown_region) return false;
          if (!q) return true;
          if (t.name.toLowerCase().includes(q)) return true;
          if (t.abbreviation && t.abbreviation.toLowerCase().includes(q)) return true;
          return t.aliases.some(a => a.alias_name.toLowerCase().includes(q));
        });

        statusEl.textContent = filtered.length + ' of ' + teams.length + ' teams';
        listEl.innerHTML = filtered.length
          ? filtered.map(cardHTML).join('')
          : '<div class="al-empty">No teams match.</div>';
      }

      function refreshAddTeamSelect() {
        addTeamSel.innerHTML = teams.map(t =>
          '<option value="' + t.team_id + '">' + esc(t.name) + (t.unknown_region ? ' (unknown region)' : '') + '</option>'
        ).join('');
      }

      async function load() {
        statusEl.textContent = 'Loading...';
        try {
          const res = await fetch('/api/admin/aliases/data', { credentials: 'include' });
          if (!res.ok) throw new Error('Request failed');
          const data = await res.json();
          teams = data.teams || [];
          refreshAddTeamSelect();
          render();
        } catch (err) {
          console.error(err);
          statusEl.textContent = 'Failed to load.';
        }
      }

      async function api(method, url, body) {
        const opts = { method, credentials: 'include', headers: { 'Content-Type': 'application/json' } };
        if (body) opts.body = JSON.stringify(body);
        const res = await fetch(url, opts);
        const data = await res.json();
        if (!res.ok || !data.success) throw new Error(data.error || 'Request failed');
        return data;
      }

      // Global add alias
      document.getElementById('al-add-btn').addEventListener('click', async () => {
        const alias_name = document.getElementById('al-add-name').value.trim();
        const team_id = Number(addTeamSel.value);
        if (!alias_name) { addMsg.textContent = 'Enter an alias name.'; return; }
        addMsg.textContent = 'Adding...';
        try {
          await api('POST', '/api/admin/aliases', { team_id, alias_name });
          document.getElementById('al-add-name').value = '';
          addMsg.textContent = 'Alias added.';
          await load();
        } catch (err) { addMsg.textContent = err.message; }
      });

      // Delegated actions inside the list
      listEl.addEventListener('click', async (e) => {
        // Delete alias
        const del = e.target.closest('.al-chip__x');
        if (del) {
          if (!confirm('Delete this alias?')) return;
          try { await api('DELETE', '/api/admin/aliases/' + del.dataset.aliasId); await load(); }
          catch (err) { alert(err.message); }
          return;
        }

        // Inline add alias
        const addBtn = e.target.closest('.al-inline-btn');
        if (addBtn) {
          const card = addBtn.closest('.al-card');
          const input = card.querySelector('.al-inline-name');
          const msg = card.querySelector('.al-card__msg');
          const alias_name = input.value.trim();
          if (!alias_name) { msg.textContent = 'Enter an alias name.'; return; }
          msg.textContent = 'Adding...';
          try {
            await api('POST', '/api/admin/aliases', { team_id: Number(addBtn.dataset.teamId), alias_name });
            await load();
          } catch (err) { msg.textContent = err.message; }
          return;
        }

        // Merge
        const mergeBtn = e.target.closest('.al-merge-btn');
        if (mergeBtn) {
          const card = mergeBtn.closest('.al-card');
          const target = Number(card.querySelector('.al-merge-target').value);
          const source = Number(mergeBtn.dataset.teamId);
          const sourceTeam = teams.find(t => t.team_id === source);
          const targetTeam = teams.find(t => t.team_id === target);
          if (!targetTeam) return;
          const msg = card.querySelector('.al-card__msg');
          if (!confirm('Merge "' + sourceTeam.name + '" INTO "' + targetTeam.name + '"?\n\nAll matches, tips and aliases move to "' + targetTeam.name + '", and "' + sourceTeam.name + '" is deleted. This cannot be undone.')) return;
          msg.textContent = 'Merging...';
          try {
            const data = await api('POST', '/api/admin/aliases/merge', { source_team_id: source, target_team_id: target });
            await load();
            statusEl.textContent = 'Merged ' + data.merged.from + ' into ' + data.merged.into
              + ' (' + data.merged.matchesReassigned + ' match refs, ' + data.merged.tipsReassigned + ' tips).';
          } catch (err) { msg.textContent = err.message; }
          return;
        }
      });

      document.getElementById('al-search').addEventListener('input', render);
      document.getElementById('al-unknown-only').addEventListener('change', render);

      load();
    })();
  </script>

  <%- include('partials/footer') %>
</body>
</html>
