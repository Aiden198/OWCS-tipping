<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin News</title>

  <link rel="stylesheet" href="/stylesheets/global.css">
  <link rel="stylesheet" href="/stylesheets/layout.css">
  <link rel="stylesheet" href="/stylesheets/components.css">
  <link rel="stylesheet" href="/stylesheets/interactive.css">
  <link rel="stylesheet" href="/stylesheets/admin.css">
  <link rel="stylesheet" href="/stylesheets/pages/adminTeams.css">
</head>

<body>
<%- include('partials/header') %>

<main class="admin-teams-page">
  <h1>Team Admin</h1>
  <p>Edit team names, ratings, regions, icons, Liquipedia links, and active status.</p>

  <div id="statusMessage"></div>

  <div class="team-search-wrapper">
    <input
        id="teamSearch"
        class="team-search-input"
        type="text"
        placeholder="Search by name, abbreviation, slug, region..."
    >
    </div>

    <div id="teamCount" class="team-count"></div>

  <div class="team-admin-table-wrapper">
    <table class="team-admin-table">
      <thead>
        <tr>
          <th>ID</th>
          <th>Icon</th>
          <th>Name</th>
          <th>Abbr</th>
          <th>Region</th>
          <th>Rating</th>
          <th>Active</th>
          <th>Slug</th>
          <th>Liquipedia Slug</th>
          <th>Save</th>
        </tr>
      </thead>

      <tbody id="teamsTableBody"></tbody>
    </table>
  </div>
</main>

<script src="/javascripts/adminTeams.js"></script>

<%- include('partials/footer') %>

</body>
</html>