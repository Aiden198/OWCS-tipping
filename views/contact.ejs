<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Contact - OWCS Tipping</title>
  <link rel="stylesheet" href="/stylesheets/global.css">
  <link rel="stylesheet" href="/stylesheets/layout.css">
  <link rel="stylesheet" href="/stylesheets/components.css">
  <link rel="stylesheet" href="/stylesheets/interactive.css">
  <link rel="stylesheet" href="/stylesheets/match-cards.css">
  <link rel="stylesheet" href="/stylesheets/pages/info.css">
</head>
<body>
  <%- include('partials/header') %>

  <main class="page-shell">
    <section class="page-hero">
      <div class="container">
        <h1>Contact</h1>
        <p>
          Get in touch regarding site issues, questions, or feedback.
        </p>
      </div>
    </section>

    <section class="page-content">
      <div class="container info-layout">
        <div class="info-card">
          <h2>General Enquiries</h2>
          <p>
            If you need to reach out about the site, a contact email or form can be added here later.
          </p>
          <p>
            For now, this page acts as a placeholder for future contact details and support options.
          </p>
        </div>

        <div class="info-card">
          <h2>Bug Reports</h2>
          <p>
            If you encounter a bug, issue, or incorrect result, this page can later be extended with
            a proper support workflow or issue submission form.
          </p>
        </div>
      </div>
    </section>
  </main>

  <%- include('partials/footer') %>
</body>
</html>

