<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Fixtures - OWCS Tipping</title>
  <link rel="stylesheet" href="/stylesheets/global.css">
  <link rel="stylesheet" href="/stylesheets/layout.css">
  <link rel="stylesheet" href="/stylesheets/components.css">
  <link rel="stylesheet" href="/stylesheets/interactive.css">
  <link rel="stylesheet" href="/stylesheets/match-cards.css">
  <link rel="stylesheet" href="/stylesheets/pages/fixtures.css">
</head>
<body>
  <%- include('partials/header') %>

  <main class="page-shell">
    <section class="page-hero">
      <div class="container">
        <h1>Fixtures</h1>
        <p>Browse upcoming OWCS matches and place your tips before they lock.</p>
        <div class="fixtures-data-credit">
          <a href="https://liquipedia.net/overwatch" target="_blank" rel="noopener noreferrer">
            <img src="/images/liquipedia_icon.png" alt="Liquipedia">
          </a>
          <span>
            Match and team data sourced from
            <a href="https://liquipedia.net/overwatch" target="_blank" rel="noopener noreferrer">Liquipedia</a>
            (CC-BY-SA)
          </span>
        </div>
      </div>
    </section>

    <section class="page-content">
      <div class="container">
        <div class="fixtures-filter-bar">
          <div class="fixtures-filter-buttons">
            <a
              href="/fixtures"
              class="fixtures-filter-btn <%= !selectedRegion ? 'fixtures-filter-btn--active' : '' %>"
            >
              All
            </a>

            <% regions.forEach(region => { %>
              <% if (region.count > 0) { %>
                <a
                  href="/fixtures?region=<%= encodeURIComponent(region.name) %>"
                  class="fixtures-filter-btn <%= selectedRegion === region.name ? 'fixtures-filter-btn--active' : '' %>"
                >
                  <%= region.name %> (<%= region.count %>)
                </a>
              <% } else { %>
                <span class="fixtures-filter-btn fixtures-filter-btn--disabled">
                  <%= region.name %> (0)
                </span>
              <% } %>
            <% }) %>
          </div>
        </div>

        <% if (user && matches.length > 0) { %>
          <div class="fixtures-global-quick-bets">
            <div class="fixtures-global-quick-bets__text">
              <h3>Quick Fill Bet Amount</h3>
              <p>
                Choose an amount to fill all visible matches. This only fills the amount field, you still need to click the team you want to tip on to place or update your tip.
              </p>
              <p>
                If you dont select a team, or already have a bet placed this will not update the tip amount. It only submits the tip if you click the team you're tipping for, even if you already have a tip placed on that match.
              </p>
            </div>

            <div class="fixtures-global-quick-bets__buttons">
              <button type="button" class="global-quick-bet-btn" data-amount="50">50</button>
              <button type="button" class="global-quick-bet-btn" data-amount="100">100</button>
              <button type="button" class="global-quick-bet-btn" data-amount="200">200</button>
              <button type="button" class="global-quick-bet-btn" data-amount="500">500</button>
              <button type="button" class="global-quick-bet-btn" data-amount="1000">1000</button>
            </div>
          </div>
        <% } %>

        <% if (matches.length === 0) { %>
          <div class="feature-card">
            <h3>No Upcoming Matches</h3>
            <% if (selectedRegion) { %>
              <p>There are currently no scheduled fixtures for <strong><%= selectedRegion %></strong>.</p>
            <% } else { %>
              <p>There are currently no scheduled fixtures to tip on.</p>
            <% } %>
          </div>
        <% } else { %>
          <div class="fixtures-list">
            <% matches.forEach((match) => {
                const existingTip = existingTips[match.match_id];
                const hasOdds = match.team_1_odds !== null && match.team_2_odds !== null;
            %>
              <div class="fixture-card">
                <div class="fixture-card__top">
                <div class="fixture-card__meta">
                  <span class="fixture-card__region">
                    <%= match.competition_region %>
                    <% if (match.stage_number) { %>
                      • Stage <%= match.stage_number %>
                    <% } %>
                    <% if (match.stage_type && match.stage_type !== 'regular_season') { %>
                      <%= match.stage_type
                        .replace(/_/g, ' ')
                        .replace(/\b\w/g, c => c.toUpperCase()) %>
                    <% } %>
                  </span>

                  <span
                    class="result-card__time local-time"
                    data-time="<%= new Date(match.match_datetime).toISOString() %>"
                  ></span>
                </div>

                  <div class="fixture-card__matchup">
                    <div class="fixture-team">
                      <img
                        src="<%= match.team_1_icon %>"
                        alt="<%= match.team_1_name %> logo"
                        class="fixture-team__logo"
                      >
                      <div class="fixture-team__text">
                        <span class="fixture-team__abbr"><%= match.team_1_abbreviation %></span>
                        <span class="fixture-team__name"><%= match.team_1_name %></span>
                      </div>
                    </div>

                    <div class="fixture-card__vs">VS</div>

                    <div class="fixture-team fixture-team--right">
                      <div class="fixture-team__text fixture-team__text--right">
                        <span class="fixture-team__abbr"><%= match.team_2_abbreviation %></span>
                        <span class="fixture-team__name"><%= match.team_2_name %></span>
                      </div>
                      <img
                        src="<%= match.team_2_icon %>"
                        alt="<%= match.team_2_name %> logo"
                        class="fixture-team__logo"
                      >
                    </div>
                  </div>
                </div>

                <div class="fixture-card__bottom">
                  <% if (user) { %>
                    <div class="fixture-tip-box">
                      <div class="fixture-tip-box__header">
                        <h3>Place Your Tip</h3>
                        <% if (existingTip) { %>
                          <span class="fixture-tip-box__status">
                            Current tip: <%= Number(existingTip.amount_tipped).toFixed(2) %>
                            <% if (existingTip.odds !== null && existingTip.odds !== undefined) { %>
                              at <%= Number(existingTip.odds).toFixed(2) %> odds
                            <% } %>
                          </span>
                        <% } %>
                      </div>

                      <div class="fixture-tip-controls" data-match-id="<%= match.match_id %>">
                        <div class="fixture-tip-amount">
                          <div class="fixture-tip-amount__header">
                            <label for="tip-amount-<%= match.match_id %>">Amount</label>
                            <span class="fixture-tip-quick-info" title="Click one of the quick amount buttons to fill the amount box, then click the team you want to tip on to save your tip.">
                              ?
                            </span>
                          </div>

                          <div class="fixture-tip-quick-bets">
                            <button type="button" class="quick-bet-btn" data-match-id="<%= match.match_id %>" data-amount="50">50</button>
                            <button type="button" class="quick-bet-btn" data-match-id="<%= match.match_id %>" data-amount="100">100</button>
                            <button type="button" class="quick-bet-btn" data-match-id="<%= match.match_id %>" data-amount="200">200</button>
                            <button type="button" class="quick-bet-btn" data-match-id="<%= match.match_id %>" data-amount="500">500</button>
                            <button type="button" class="quick-bet-btn" data-match-id="<%= match.match_id %>" data-amount="1000">1000</button>
                          </div>

                          <p class="fixture-tip-help-text">
                            Quick buttons only fill the amount. You still need to click the team you want to tip on.
                          </p>

                          <input
                            type="number"
                            min="1"
                            step="10"
                            id="tip-amount-<%= match.match_id %>"
                            class="tip-amount-input"
                            placeholder="Enter credits"
                            value="<%= existingTip ? Number(existingTip.amount_tipped).toFixed(2) : '' %>"
                          >
                        </div>

                        <div class="fixture-tip-buttons">
                          <button
                            class="tip-team-btn <%= existingTip && existingTip.selected_team_id === match.team_1_db_id ? 'tip-team-btn--selected' : '' %>"
                            data-match-id="<%= match.match_id %>"
                            data-team-id="<%= match.team_1_db_id %>"
                            data-odds="<%= match.team_1_odds %>"
                            <%= hasOdds ? '' : 'disabled' %>
                          >
                            <% if (hasOdds) { %>
                              Tip <%= match.team_1_abbreviation %> @ <%= Number(match.team_1_odds).toFixed(2) %>
                            <% } else { %>
                              Tip <%= match.team_1_abbreviation %> (odds coming soon)
                            <% } %>
                          </button>

                          <button
                            class="tip-team-btn <%= existingTip && existingTip.selected_team_id === match.team_2_db_id ? 'tip-team-btn--selected' : '' %>"
                            data-match-id="<%= match.match_id %>"
                            data-team-id="<%= match.team_2_db_id %>"
                            data-odds="<%= match.team_2_odds %>"
                            <%= hasOdds ? '' : 'disabled' %>
                          >
                            <% if (hasOdds) { %>
                              Tip <%= match.team_2_abbreviation %> @ <%= Number(match.team_2_odds).toFixed(2) %>
                            <% } else { %>
                              Tip <%= match.team_2_abbreviation %> (odds coming soon)
                            <% } %>
                          </button>
                        </div>
                      </div>
                    </div>
                  <% } else { %>
                    <div class="fixture-login-prompt">
                      <p>You must be logged in to place tips on fixtures.</p>
                      <a href="/login" class="btn btn-secondary">Log In</a>
                    </div>
                  <% } %>
                </div>
              </div>
            <% }) %>
          </div>
        <% } %>
      </div>
    </section>
  </main>

  <script>
    document.querySelectorAll('.tip-team-btn').forEach((button) => {
      button.addEventListener('click', async () => {
        const matchId = button.dataset.matchId;
        const teamId = button.dataset.teamId;
        const odds = button.dataset.odds;
        const amountInput = document.getElementById(`tip-amount-${matchId}`);
        const amount = amountInput.value;

        if (!amount || Number(amount) <= 0) {
          alert('Please enter a valid tip amount.');
          return;
        }

        if (!odds || odds === 'null') {
          alert('Odds are not available for this match yet.');
          return;
        }

        try {
          const res = await fetch('/api/tips', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            credentials: 'include',
            body: JSON.stringify({
              match_id: matchId,
              selected_team_id: teamId,
              odds: odds,
              amount_tipped: amount
            })
          });

          const data = await res.text();

          if (!res.ok) {
            alert(data);
            return;
          }

          alert('Tip saved successfully.');
          window.location.reload();
        } catch (err) {
          console.error(err);
          alert('Error saving tip.');
        }
      });
    });
  </script>
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const timeElements = document.querySelectorAll('.local-time');

      timeElements.forEach(el => {
        const timeValue = el.dataset.time;
        const date = new Date(timeValue);

        el.textContent = date.toLocaleString(undefined, {
          weekday: 'short',
          day: 'numeric',
          month: 'short',
          year: 'numeric',
          hour: 'numeric',
          minute: '2-digit',
          hour12: true,
        });
      });
    });
  </script>
  <script>
    document.querySelectorAll('.global-quick-bet-btn').forEach((button) => {
      button.addEventListener('click', () => {
        const amount = button.dataset.amount;

        document.querySelectorAll('.tip-amount-input').forEach((input) => {
          input.value = amount;
        });

        document
          .querySelectorAll('.global-quick-bet-btn')
          .forEach((btn) => btn.classList.remove('global-quick-bet-btn--selected'));

        button.classList.add('global-quick-bet-btn--selected');

        document.querySelectorAll('.quick-bet-btn').forEach((btn) => {
          if (btn.dataset.amount === amount) {
            btn.classList.add('quick-bet-btn--selected');
          } else {
            btn.classList.remove('quick-bet-btn--selected');
          }
        });
      });
    });

    document.querySelectorAll('.quick-bet-btn').forEach((button) => {
      button.addEventListener('click', () => {
        const matchId = button.dataset.matchId;
        const amount = button.dataset.amount;
        const amountInput = document.getElementById(`tip-amount-${matchId}`);

        if (!amountInput) return;

        amountInput.value = amount;

        document
          .querySelectorAll(`.quick-bet-btn[data-match-id="${matchId}"]`)
          .forEach((btn) => btn.classList.remove('quick-bet-btn--selected'));

        button.classList.add('quick-bet-btn--selected');
      });
    });
  </script>

  <%- include('partials/footer') %>
</body>
</html>