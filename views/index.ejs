<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>OWCS Tipping</title>
  <link rel="stylesheet" href="/stylesheets/global.css">
  <link rel="stylesheet" href="/stylesheets/layout.css">
  <link rel="stylesheet" href="/stylesheets/components.css">
  <link rel="stylesheet" href="/stylesheets/interactive.css">
  <link rel="stylesheet" href="/stylesheets/match-cards.css">
  <link rel="stylesheet" href="/stylesheets/pages/home.css">
  <link rel="icon" href="/favicon.ico" type="image/x-icon">
</head>
<body>
  <%- include('partials/header') %>

  <main>
    <section class="hero">
      <div class="container hero__grid">
        <div class="hero__text">
          <h1>Tip OWCS Matches.<br>Climb the Leaderboard.</h1>
          <p>
            Follow upcoming Overwatch Champions Series matches, submit your predictions,
            and compete against others to see who knows the scene best.
          </p>

          <div class="hero__actions">
            <a href="/fixtures" class="btn btn-primary">Start Tipping</a>
            <a href="/leaderboard" class="btn btn-secondary">View Leaderboard</a>
          </div>

          <p class="hero__notice">
            This is an unofficial, independent tipping platform for OWCS matches and is not the official OWCS website.
          </p>
          <div class="hero-data-credit">
            <a href="https://liquipedia.net/overwatch" target="_blank" rel="noopener noreferrer">
              <img src="/images/liquipedia_icon.png" alt="Liquipedia">
            </a>
            <span>
              Match and team data sourced from
              <a href="https://liquipedia.net/overwatch" target="_blank" rel="noopener noreferrer">Liquipedia</a>
              (CC-BY-SA)
            </span>
          </div>
        </div>

        <div class="hero-card">
          <h3>Upcoming Matches</h3>

          <div class="match-list">
            <% featuredMatches.forEach((match) => { %>
              <div class="match-item">
                <span class="result-card__time match-countdown" data-time="<%= match.match_datetime %>" style="padding: 10rem;"></span>
                <div class="match-item__teams">
                  <div class="match-team">
                    <img src="<%= match.team1.icon %>" alt="<%= match.team1.name %> logo" class="match-team__logo">
                    <span class="match-team__abbr"><%= match.team1.abbreviation %></span>
                  </div>

                  <span class="match-item__vs">vs</span>

                  <div class="match-team">
                    <img src="<%= match.team2.icon %>" alt="<%= match.team2.name %> logo" class="match-team__logo">
                    <span class="match-team__abbr"><%= match.team2.abbreviation %></span>
                  </div>
                </div>
              </div>
            <% }) %>
          </div>

        </div>
      </div>
    </section>

    <% if (recentResolvedTips && recentResolvedTips.length > 0) { %>
    <section class="recent-results-section">
      <div class="container">
        <div class="home-section-heading">
          <h2>Your Recent Results</h2>
          <p>Your latest resolved OWCS tips.</p>
        </div>

        <div class="recent-results-grid">
          <% recentResolvedTips.forEach((tip) => { %>
            <div class="recent-tip-card <%= tip.status === 'won' ? 'recent-tip-card--won' : 'recent-tip-card--lost' %>">

              <div class="recent-tip-card__top">
                <div>
                  <span class="recent-tip-card__status">
                    <%= tip.status === 'won' ? 'Won Tip' : 'Lost Tip' %>
                  </span>

                  <p class="recent-tip-card__picked">
                    Picked <strong><%= tip.selected_team_abbreviation %></strong>
                  </p>
                </div>

                <span class="recent-tip-card__amount">
                  <%= tip.profit >= 0 ? '+' : '-' %><%= Math.abs(tip.profit).toFixed(2) %>
                </span>
              </div>

              <div class="recent-tip-card__match">
                <div class="match-team">
                  <img src="<%= tip.team1_icon %>" alt="<%= tip.team1_name %>" class="match-team__logo">
                  <span class="match-team__abbr"><%= tip.team1_abbreviation %></span>
                </div>

                <span class="recent-tip-card__score">
                  <%= tip.team_1_score %> - <%= tip.team_2_score %>
                </span>

                <div class="match-team">
                  <img src="<%= tip.team2_icon %>" alt="<%= tip.team2_name %>" class="match-team__logo">
                  <span class="match-team__abbr"><%= tip.team2_abbreviation %></span>
                </div>
              </div>

            </div>
          <% }) %>
        </div>
      </div>
    </section>
    <% } %>

    <section class="how-it-works">
      <div class="container">
        <div class="how-it-works__content">
          <h2>How to use the site</h2>
          <p>
            To place tips, you need to create an account so your credits and match tips can be tracked.
          </p>
          <p>
            Once you have an account, head to the Fixtures page, enter the amount you want to tip,
            and select the team you want to back.
          </p>

          <h3 class="credit-FAQ">What if I run out of credits?</h3>
          <p>
            Every couple of days, accounts with fewer than 500 credits are topped back up to 500,
            so everyone can keep playing even after an unlucky streak.
          </p>
        </div>
      </div>
    </section>
    <section class="features">
      <div class="container">
        <h2 class="section-title">What you can do</h2>

        <div class="feature-grid">
          <div class="feature-card">
            <h3>Submit Predictions</h3>
            <p>
              Make your tips for upcoming OWCS matches and lock in your picks before games begin.
            </p>
          </div>

          <div class="feature-card">
            <h3>Track Results</h3>
            <p>
              See how your predictions performed and keep up with completed matches and outcomes.
            </p>
          </div>

          <div class="feature-card">
            <h3>Compete on the Ladder</h3>
            <p>
              Compare your performance against other users and push your way up the tipping leaderboard.
            </p>
          </div>
        </div>
      </div>
    </section>

    <section class="live-now-section" id="live-now-section" hidden>
      <div class="container">
        <div class="live-now-header">
          <h2>OWCS is Live</h2>
          <p>Watch the official OWCS broadcast now.</p>
        </div>

        <div class="live-now-list" id="live-now-list"></div>
      </div>
    </section>

    <section class="home-news-section">
      <div class="container">
        <div class="home-section-heading">
          <h2>Latest News</h2>
          <p>Updates about tournaments, regional results, and OWCS Tipping changes.</p>
        </div>

          <% if (user && user.is_admin) { %>
            <a href="/adminNews" class="btn btn-secondary" style="margin-bottom: 1rem;">Edit News</a>
          <% } %>

        <% if (!newsItems || newsItems.length === 0) { %>
          <div class="feature-card">
            <h3>No News Yet</h3>
            <p>News updates will appear here once available.</p>
          </div>
        <% } else { %>
          <div class="home-news-grid" id="news-grid">
            <% newsItems.forEach((item, index) => { %>
              <article class="home-news-card <%= index >= 3 ? 'hidden-news' : '' %>">
                <div class="home-news-card__top">
                  <span class="home-news-card__category"><%= item.type.replace('_', ' ') %></span>
                  <span class="home-news-card__date">
                    <%= item.published_at ? new Date(item.published_at).toLocaleDateString('en-AU') : '' %>
                  </span>
                </div>

                <% if (item.image_url) { %>
                  <img src="<%= item.image_url %>" alt="" class="home-news-card__image">
                <% } %>

                <h3><%= item.title %></h3>
                <p><%= item.body %></p>

                <% if (item.source_url) { %>
                  <a href="<%= item.source_url %>" class="home-news-card__link" target="_blank">
                    View Source
                  </a>
                <% } %>
              </article>
            <% }) %>
          </div>

          <% if (newsItems.length > 3) { %>
            <div class="home-news-more">
              <button id="news-toggle-btn" class="home-news-more-btn">
                Show More
              </button>
            </div>
          <% } %>
        <% } %>
      </div>
    </section>

    <% if (biggestUpset) { %>
    <section class="home-upset-section">
      <div class="container">
        <div class="home-section-heading">
          <h2>Biggest Upset This Month</h2>
          <p>The largest underdog victory in OWCS over the past month (in the admins humble opinion).</p>
        </div>

        <article class="biggest-upset-card">
          <div class="biggest-upset-card__teams">
            <div class="biggest-upset-team">
              <img
                src="<%= biggestUpset.winner_icon %>"
                alt="<%= biggestUpset.winner_name %>"
              >
              <span><%= biggestUpset.winner_name %></span>
            </div>

            <span class="biggest-upset-vs">
              <%= biggestUpset.winner_score %> - <%= biggestUpset.loser_score %>
            </span>

            <div class="biggest-upset-team">
              <img
                src="<%= biggestUpset.loser_icon %>"
                alt="<%= biggestUpset.loser_name %>"
              >
              <span><%= biggestUpset.loser_name %></span>
            </div>
          </div>

          <div class="biggest-upset-details">
            <strong>
              <%= Number(biggestUpset.winner_odds).toFixed(2) %>x underdog victory
            </strong>

            <% if (biggestUpset.source_url) { %>
              <a
                href="<%= biggestUpset.source_url %>"
                target="_blank"
                class="home-news-card__link"
              >
                View Match Source
              </a>
            <% } %>
          </div>
        </article>
      </div>
    </section>
    <% } %>

  </main>
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const timeElements = document.querySelectorAll('.local-time');

      timeElements.forEach(el => {
        const timeValue = el.dataset.time;
        const date = new Date(timeValue);

        if (isNaN(date.getTime())) {
          el.textContent = 'Time unavailable';
          return;
        }

        el.textContent = date.toLocaleString(undefined, {
          weekday: 'short',
          day: 'numeric',
          month: 'short',
          year: 'numeric',
          hour: 'numeric',
          minute: '2-digit',
          hour12: true,
        });
      });
    });
  </script>

  <script>
    const btn = document.getElementById('news-toggle-btn');

    if (btn) {
      let expanded = false;

      btn.addEventListener('click', () => {
        const hiddenItems = document.querySelectorAll('.hidden-news');

        expanded = !expanded;

        hiddenItems.forEach(item => {
          item.style.display = expanded ? 'block' : 'none';
        });

        btn.textContent = expanded ? 'Show Less' : 'Show More';
      });
    }
  </script>

  <script>
    async function loadLiveStreams() {
      try {
        const res = await fetch('/api/twitch/live');
        const streams = await res.json();

        if (!streams || streams.length === 0) return;

        const section = document.getElementById('live-now-section');
        const list = document.getElementById('live-now-list');

        list.innerHTML = streams.map(stream => `
          <div class="live-now-card live-now-card--embed">
            <div class="live-now-player">
              <iframe
                src="https://player.twitch.tv/?channel=${stream.channel}&parent=${window.location.hostname}&muted=true"
                allowfullscreen>
              </iframe>
            </div>

            <div class="live-now-info">
              <div class="live-now-title-row">
                <span class="live-pill">LIVE</span>
                <h3>${stream.channelName}</h3>
              </div>

              <p>${stream.title}</p>
              <small>${stream.viewerCount.toLocaleString()} viewers</small>

              <a href="${stream.url}" target="_blank" rel="noopener" class="btn btn-secondary">
                Open on Twitch
              </a>
            </div>
          </div>
        `).join('');

        section.hidden = false;
      } catch (err) {
        console.error('Failed to load Twitch live streams:', err);
      }
    }

    loadLiveStreams();
  </script>

  <script>
    function updateCountdowns() {
      const elements = document.querySelectorAll('.match-countdown');

      elements.forEach(el => {
        const target = new Date(el.dataset.time);
        const now = new Date();

        const diff = target - now;

        if (diff <= 0) {
          el.textContent = 'LIVE';
          return;
        }

        const totalSeconds = Math.floor(diff / 1000);

        const days = Math.floor(totalSeconds / (60 * 60 * 24));
        const hours = Math.floor((totalSeconds % (60 * 60 * 24)) / (60 * 60));
        const minutes = Math.floor((totalSeconds % (60 * 60)) / 60);

        if (days > 0) {
          el.textContent = `${days}d ${hours}h`;
        } else if (hours > 0) {
          el.textContent = `${hours}h ${minutes}m`;
        } else {
          el.textContent = `${minutes}m`;
        }
      });
    }

    updateCountdowns();
    setInterval(updateCountdowns, 60000);
  </script>
  <%- include('partials/footer') %>
</body>
</html>