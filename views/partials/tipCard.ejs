<% if (isPast) { %>
  <% const odds = Number(tip.odds || 0); %>
  <% const amountTipped = Number(tip.amount_tipped || 0); %>
  <% const potentialPayout = Number(tip.potential_payout || 0); %>
  <% const tippedCorrectly = tip.status === 'won'; %>
  <% const netChange = tippedCorrectly ? potentialPayout - amountTipped : -amountTipped; %>

  <div class="result-card">
    <div class="result-card__top">
      <div class="result-card__meta">
        <span class="result-card__region">
          <%= tip.competition_region %>
          <% if (tip.stage_number) { %>
            • Stage <%= tip.stage_number %>
          <% } %>
          <% if (tip.stage_type && tip.stage_type !== 'regular_season') { %>
            • <%= tip.stage_type.replace(/_/g, ' ').replace(/\b\w/g, c => c.toUpperCase()) %>
          <% } %>
        </span>

        <span class="result-card__time local-time" data-time="<%= tip.match_datetime %>"></span>
      </div>

      <div class="result-card__matchup">
        <div class="result-team">
          <img src="<%= tip.team_1_icon %>" alt="<%= tip.team_1_name %> logo" class="result-team__logo">
          <div class="result-team__text">
            <span class="result-team__abbr"><%= tip.team_1_abbreviation %></span>
            <span class="result-team__name"><%= tip.team_1_name %></span>
          </div>
        </div>

        <div class="result-card__scoreblock">
          <span class="result-card__score">
            <%= tip.team_1_score ?? 0 %> - <%= tip.team_2_score ?? 0 %>
          </span>
          <span class="result-card__status">Final</span>
        </div>

        <div class="result-team result-team--right">
          <div class="result-team__text result-team__text--right">
            <span class="result-team__abbr"><%= tip.team_2_abbreviation %></span>
            <span class="result-team__name"><%= tip.team_2_name %></span>
          </div>
          <img src="<%= tip.team_2_icon %>" alt="<%= tip.team_2_name %> logo" class="result-team__logo">
        </div>
      </div>
    </div>

    <div class="result-card__bottom">
      <div class="result-tip-box">
        <div class="result-tip-box__header">
          <h3>Your Tip</h3>
          <span class="result-tip-box__badge <%= tippedCorrectly ? 'result-tip-box__badge--win' : 'result-tip-box__badge--loss' %>">
            <%= tippedCorrectly ? 'Won' : 'Lost' %>
          </span>
        </div>

        <div class="result-tip-grid">
          <div class="result-tip-detail">
            <span class="result-tip-detail__label">Your Pick</span>
            <span class="result-tip-detail__value">
              <%= tip.selected_team_abbreviation %> — <%= tip.selected_team_name %>
            </span>
          </div>

          <div class="result-tip-detail">
            <span class="result-tip-detail__label">Odds</span>
            <span class="result-tip-detail__value"><%= odds.toFixed(2) %></span>
          </div>

          <div class="result-tip-detail">
            <span class="result-tip-detail__label">Amount Tipped</span>
            <span class="result-tip-detail__value"><%= amountTipped.toFixed(2) %> credits</span>
          </div>

          <div class="result-tip-detail">
            <span class="result-tip-detail__label">Outcome</span>
            <span class="result-tip-detail__value <%= tippedCorrectly ? 'result-tip-detail__value--win' : 'result-tip-detail__value--loss' %>">
              <%= netChange > 0 ? '+' : '' %><%= netChange.toFixed(2) %> credits
            </span>
          </div>
        </div>
      </div>
    </div>
  </div>
<% } else { %>
  <div class="my-tip-card">
    <div class="my-tip-card__top">
      <div class="my-tip-card__meta">
        <span class="my-tip-card__region">
          <%= tip.competition_region %>
          <% if (tip.stage_number) { %>
            • Stage <%= tip.stage_number %>
          <% } %>
          <% if (tip.stage_type && tip.stage_type !== 'regular_season') { %>
            • <%= tip.stage_type.replace(/_/g, ' ').replace(/\b\w/g, c => c.toUpperCase()) %>
          <% } %>
        </span>

        <span class="result-card__time local-time" data-time="<%= tip.match_datetime %>"></span>
      </div>

      <div class="my-tip-card__matchup">
        <div class="my-tip-team">
          <img src="<%= tip.team_1_icon %>" alt="<%= tip.team_1_name %> logo" class="my-tip-team__logo">
          <div class="my-tip-team__text">
            <span class="my-tip-team__abbr"><%= tip.team_1_abbreviation %></span>
            <span class="my-tip-team__name"><%= tip.team_1_name %></span>
          </div>
        </div>

        <div class="my-tip-card__vs">VS</div>

        <div class="my-tip-team my-tip-team--right">
          <div class="my-tip-team__text my-tip-team__text--right">
            <span class="my-tip-team__abbr"><%= tip.team_2_abbreviation %></span>
            <span class="my-tip-team__name"><%= tip.team_2_name %></span>
          </div>
          <img src="<%= tip.team_2_icon %>" alt="<%= tip.team_2_name %> logo" class="my-tip-team__logo">
        </div>
      </div>
    </div>

    <div class="my-tip-card__bottom">
      <div class="my-tip-details-grid">
        <div class="my-tip-detail">
          <span class="my-tip-detail__label">Your Pick</span>
          <span class="my-tip-detail__value"><%= tip.selected_team_abbreviation %> — <%= tip.selected_team_name %></span>
        </div>

        <div class="my-tip-detail">
          <span class="my-tip-detail__label">Odds at Tip Time</span>
          <span class="my-tip-detail__value"><%= Number(tip.odds).toFixed(2) %></span>
        </div>

        <div class="my-tip-detail">
          <span class="my-tip-detail__label">Amount Tipped</span>
          <span class="my-tip-detail__value"><%= Number(tip.amount_tipped).toFixed(2) %></span>
        </div>

        <div class="my-tip-detail">
          <span class="my-tip-detail__label">Potential Payout</span>
          <span class="my-tip-detail__value my-tip-detail__value--highlight"><%= Number(tip.potential_payout).toFixed(2) %></span>
        </div>

        <div class="my-tip-detail">
          <span class="my-tip-detail__label">Tip Status</span>
          <span class="my-tip-detail__value">Pending</span>
        </div>

        <div class="my-tip-detail">
          <span class="my-tip-detail__label">Placed At</span>
          <span class="result-card__time local-time" data-time="<%= tip.tip_time %>"></span>
        </div>
      </div>
    </div>
  </div>
<% } %>