<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Privacy - OWCS Tipping</title>
  <link rel="stylesheet" href="/stylesheets/global.css">
  <link rel="stylesheet" href="/stylesheets/layout.css">
  <link rel="stylesheet" href="/stylesheets/components.css">
  <link rel="stylesheet" href="/stylesheets/interactive.css">
  <link rel="stylesheet" href="/stylesheets/match-cards.css">
  <link rel="stylesheet" href="/stylesheets/pages/info.css">
</head>
<body>
  <%- include('partials/header') %>

  <main class="page-shell">
    <section class="page-hero">
      <div class="container">
        <h1>Privacy</h1>
        <p>
          Basic information about how account and tipping data is handled on this platform.
        </p>
      </div>
    </section>

    <section class="page-content">
      <div class="container info-layout">
        <div>
          <h2>Account Information</h2>
          <p>
            This site may store account details such as name, email address, password hash, profile picture,
            and tipping-related data in order to provide account functionality and site features.
          </p>
        </div>

        <div>
          <h2>Site Usage Data</h2>
          <p>
            Match tips, credits, leaderboard positions, and related in-site activity may be stored and processed
            as part of the platform’s normal operation.
          </p>
        </div>

        <div>
          <h2>Development Status</h2>
          <p>
            This page is currently a simplified placeholder and may later be expanded into a fuller privacy notice
            if the project grows beyond its current scope.
          </p>
        </div>
      </div>
    </section>
  </main>

  <%- include('partials/footer') %>
</body>
</html>