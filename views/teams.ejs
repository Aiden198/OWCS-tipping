<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Teams - OWCS Tipping</title>
  <link rel="stylesheet" href="/stylesheets/global.css">
  <link rel="stylesheet" href="/stylesheets/layout.css">
  <link rel="stylesheet" href="/stylesheets/components.css">
  <link rel="stylesheet" href="/stylesheets/interactive.css">
  <link rel="stylesheet" href="/stylesheets/match-cards.css">
  <link rel="stylesheet" href="/stylesheets/pages/teams.css">
</head>
<body>
  <%- include('partials/header') %>

  <main class="page-shell">
  <section class="page-hero">
    <div class="container">
      <h1>Teams</h1>
      <p>
        Browse OWCS teams by region. Team entries will link out to their Liquipedia pages once added.
      </p>

      <div class="teams-data-credit">
        <a href="https://liquipedia.net/overwatch" target="_blank" rel="noopener noreferrer">
          <img src="/images/liquipedia_icon.png" alt="Liquipedia">
        </a>
        <span>
          Team data sourced from
          <a href="https://liquipedia.net/overwatch" target="_blank" rel="noopener noreferrer">Liquipedia</a>
          (CC-BY-SA)
        </span>
      </div>
    </div>
  </section>

    <section class="page-content">
      <div class="container">
        <% if (!teamsByRegion || Object.keys(teamsByRegion).length === 0) { %>
          <div class="feature-card">
            <h3>No Teams Found</h3>
            <p>There are currently no teams available to display.</p>
          </div>
        <% } else { %>
          <div class="teams-sections">
            <% Object.keys(teamsByRegion).forEach((region) => { %>
              <section class="teams-region-section">
                <div class="teams-region-header">
                  <h2><%= region %></h2>
                </div>

                <div class="teams-grid">
                  <% teamsByRegion[region].forEach((team) => { %>
                    <% if (team.liquipedia_url) { %>
                      <a
                        href="<%= team.liquipedia_url %>"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="team-card"
                      >
                        <img src="<%= team.icon_path %>" alt="<%= team.name %> logo" class="team-card__logo">
                        <div class="team-card__text">
                          <span class="team-card__abbr"><%= team.abbreviation %></span>
                          <span class="team-card__name"><%= team.name %></span>
                        </div>
                      </a>
                    <% } else { %>
                      <div class="team-card team-card--disabled">
                        <img src="<%= team.icon_path %>" alt="<%= team.name %> logo" class="team-card__logo">
                        <div class="team-card__text">
                          <span class="team-card__abbr"><%= team.abbreviation %></span>
                          <span class="team-card__name"><%= team.name %></span>
                          <span class="team-card__note">Liquipedia link coming soon</span>
                        </div>
                      </div>
                    <% } %>
                  <% }) %>
                </div>
              </section>
            <% }) %>
          </div>
        <% } %>
      </div>
    </section>
  </main>

  <%- include('partials/footer') %>
</body>
</html>