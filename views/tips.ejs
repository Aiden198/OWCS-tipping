<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>My Tips - OWCS Tipping</title>
  <link rel="stylesheet" href="/stylesheets/global.css">
  <link rel="stylesheet" href="/stylesheets/layout.css">
  <link rel="stylesheet" href="/stylesheets/components.css">
  <link rel="stylesheet" href="/stylesheets/interactive.css">
  <link rel="stylesheet" href="/stylesheets/match-cards.css">
  <link rel="stylesheet" href="/stylesheets/pages/tips.css">
  <link rel="icon" href="/favicon.ico" type="image/x-icon">
</head>
<body>
  <%- include('partials/header') %>

  <main class="page-shell">
    <section class="page-hero">
      <div class="container">
        <h1>My Tips</h1>
        <p>View your active tips, past tips, locked-in odds, and results.</p>

        <div class="tips-data-credit">
          <a href="https://liquipedia.net/overwatch" target="_blank" rel="noopener noreferrer">
            <img src="/images/liquipedia_icon.png" alt="Liquipedia">
          </a>
          <span>
            Match and team data sourced from
            <a href="https://liquipedia.net/overwatch" target="_blank" rel="noopener noreferrer">Liquipedia</a>
            (CC-BY-SA)
          </span>
        </div>
      </div>
    </section>

    <section class="page-content">
      <div class="container">

        <div class="tips-tabs">
          <button class="tips-tab active" data-tab="active">Active Tips</button>
          <button class="tips-tab" data-tab="past">Past Tips</button>
        </div>

        <div id="active-tips-section" class="tips-tab-section">
          <% if (!activeTips || activeTips.length === 0) { %>
            <div class="feature-card">
              <h3>No Active Tips</h3>
              <p>You have not placed any tips on upcoming matches yet.</p>
            </div>
          <% } else { %>
            <div class="my-tips-list">
              <% activeTips.forEach((tip) => { %>
                <%- include('partials/tipCard', { tip: tip, isPast: false }) %>
              <% }) %>
            </div>
          <% } %>
        </div>

        <div id="past-tips-section" class="tips-tab-section" style="display: none;">
          <% if (!pastTips || pastTips.length === 0) { %>
            <div class="feature-card">
              <h3>No Past Tips</h3>
              <p>Your resolved tips will appear here after matches finish.</p>
            </div>
          <% } else { %>
            <div class="my-tips-list">
              <% pastTips.forEach((tip) => { %>
                <%- include('partials/tipCard', { tip: tip, isPast: true }) %>
              <% }) %>
            </div>
          <% } %>
        </div>

      </div>
    </section>
  </main>

  <%- include('partials/footer') %>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('.local-time').forEach(el => {
      const timeValue = el.dataset.time;
      const date = new Date(timeValue);

      if (isNaN(date.getTime())) {
        el.textContent = 'Time unavailable';
        return;
      }

      el.textContent = date.toLocaleString(undefined, {
        weekday: 'short',
        day: 'numeric',
        month: 'short',
        year: 'numeric',
        hour: 'numeric',
        minute: '2-digit',
        hour12: true,
      });
    });

    const tabs = document.querySelectorAll('.tips-tab');
    const activeSection = document.getElementById('active-tips-section');
    const pastSection = document.getElementById('past-tips-section');

    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        tabs.forEach(btn => btn.classList.remove('active'));
        tab.classList.add('active');

        if (tab.dataset.tab === 'active') {
          activeSection.style.display = 'block';
          pastSection.style.display = 'none';
        } else {
          activeSection.style.display = 'none';
          pastSection.style.display = 'block';
        }
      });
    });
  });
</script>
</body>
</html>